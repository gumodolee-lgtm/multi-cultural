# ============================================================
# 다문화 정보 허브 — 환경 변수 템플릿
# 이 파일을 .env 로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# ------------------------------------------------------------
# 법제처 Open API (law.go.kr)
# OC 값 = 본인 이메일 주소의 @ 앞부분
# 예) 이메일이 hong123@naver.com 이면 → LAW_API_OC=hong123
# 테스트용: LAW_API_OC=test (회원가입 없이 동작, 기능 제한)
# 정식 사용: law.go.kr → OPEN API 신청 → 회원가입 후 이메일 ID 입력
# ------------------------------------------------------------
LAW_API_OC=test

# ------------------------------------------------------------
# 공공데이터포털 API 키 (data.go.kr — 지원사업 데이터용)
# https://www.data.go.kr → 회원가입 → 원하는 데이터셋 활용신청
# 현재는 선택사항. 지원사업 기능 구현 시 필요.
# ------------------------------------------------------------
PUBLIC_DATA_API_KEY=

# ------------------------------------------------------------
# 번역 API (선택 — 없으면 번역 기능 비활성화)
# DeepL: https://www.deepl.com/ko/pro-api
# ------------------------------------------------------------
DEEPL_API_KEY=

# ------------------------------------------------------------
# AI 요약 API (선택 — 없으면 AI 요약 기능 비활성화)
# Anthropic: https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
